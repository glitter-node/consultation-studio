{
    "version": "1.0.0",
    "layout_name": "auth_forgot_password",
    "extends": "_consultation_public_base",
    "permissions": [],
    "meta": {
        "title": "Consultation Password Recovery"
    },
    "init_actions": [
        {
            "handler": "setState",
            "params": {
                "target": "local",
                "isSendingReset": false,
                "forgotPasswordError": null,
                "forgotPasswordErrors": null,
                "forgotPasswordSuccess": false
            }
        }
    ],
    "slots": {
        "hero": [
            {
                "id": "auth_forgot_password_hero",
                "type": "basic",
                "name": "Div",
                "props": {
                    "className": "cs-panel cs-home-hero"
                },
                "children": [
                    {
                        "type": "basic",
                        "name": "Span",
                        "props": {
                            "className": "cs-step-label"
                        },
                        "text": "Password Recovery"
                    },
                    {
                        "type": "basic",
                        "name": "H1",
                        "props": {
                            "className": "cs-page-title"
                        },
                        "text": "Reset Access to Your Account"
                    }
                ]
            }
        ],
        "page_intro": [
            {
                "id": "auth_forgot_password_intro",
                "type": "basic",
                "name": "Div",
                "props": {
                    "className": "cs-panel"
                },
                "children": [
                    {
                        "type": "basic",
                        "name": "P",
                        "props": {
                            "className": "cs-page-copy"
                        },
                        "text": "Enter the email address registered with your account. The existing Gnuboard 7 password recovery flow will send reset instructions to that inbox."
                    }
                ]
            }
        ],
        "main_content": [
            {
                "id": "auth_forgot_password_content",
                "type": "basic",
                "name": "Div",
                "props": {
                    "className": "cs-page-grid cs-lookup-shell"
                },
                "children": [
                    {
                        "id": "auth_forgot_password_form",
                        "type": "basic",
                        "name": "Form",
                        "props": {
                            "id": "auth_forgot_password_form",
                            "className": "cs-panel cs-form-grid"
                        },
                        "actions": [
                            {
                                "type": "submit",
                                "handler": "sequence",
                                "actions": [
                                    {
                                        "handler": "setState",
                                        "params": {
                                            "target": "local",
                                            "isSendingReset": true,
                                            "forgotPasswordError": null,
                                            "forgotPasswordErrors": null
                                        }
                                    },
                                    {
                                        "handler": "apiCall",
                                        "target": "/api/auth/forgot-password",
                                        "params": {
                                            "method": "POST",
                                            "body": {
                                                "email": "{{form.email}}"
                                            }
                                        },
                                        "onSuccess": [
                                            {
                                                "handler": "setState",
                                                "params": {
                                                    "target": "local",
                                                    "isSendingReset": false,
                                                    "forgotPasswordError": null,
                                                    "forgotPasswordErrors": null,
                                                    "forgotPasswordSuccess": true
                                                }
                                            }
                                        ],
                                        "onError": [
                                            {
                                                "handler": "setState",
                                                "params": {
                                                    "target": "local",
                                                    "isSendingReset": false,
                                                    "forgotPasswordError": "{{error.response?.message ?? error.message}}",
                                                    "forgotPasswordErrors": "{{error.response?.errors ?? error.errors}}"
                                                }
                                            }
                                        ]
                                    }
                                ]
                            }
                        ],
                        "children": [
                            {
                                "type": "basic",
                                "name": "H2",
                                "props": {
                                    "className": "cs-block-title"
                                },
                                "text": "Forgot Password"
                            },
                            {
                                "type": "basic",
                                "name": "P",
                                "if": "{{_local.forgotPasswordError}}",
                                "props": {
                                    "className": "cs-auth-message cs-auth-message-error",
                                    "role": "alert",
                                    "aria-live": "polite"
                                },
                                "text": "{{_local.forgotPasswordError}}"
                            },
                            {
                                "type": "basic",
                                "name": "Div",
                                "if": "{{_local.forgotPasswordSuccess}}",
                                "props": {
                                    "className": "cs-auth-message cs-auth-message-success",
                                    "role": "status",
                                    "aria-live": "polite"
                                },
                                "children": [
                                    {
                                        "type": "basic",
                                        "name": "P",
                                        "text": "If the email exists in the system, password reset instructions have been sent. Check your inbox and follow the link to continue."
                                    }
                                ]
                            },
                            {
                                "type": "basic",
                                "name": "Div",
                                "if": "{{!_local.forgotPasswordSuccess}}",
                                "children": [
                                    {
                                        "type": "basic",
                                        "name": "Label",
                                        "props": {
                                            "className": "cs-summary-label"
                                        },
                                        "text": "Email"
                                    },
                                    {
                                        "type": "basic",
                                        "name": "Input",
                                        "props": {
                                            "name": "email",
                                            "type": "email",
                                            "placeholder": "Email address",
                                            "className": "cs-input",
                                            "disabled": "{{_local.isSendingReset}}",
                                            "required": true
                                        }
                                    },
                                    {
                                        "type": "basic",
                                        "name": "P",
                                        "if": "{{_local.forgotPasswordErrors?.email}}",
                                        "props": {
                                            "className": "cs-auth-field-error"
                                        },
                                        "text": "{{Array.isArray(_local.forgotPasswordErrors?.email) ? _local.forgotPasswordErrors.email[0] : _local.forgotPasswordErrors?.email}}"
                                    }
                                ]
                            },
                            {
                                "type": "basic",
                                "name": "Button",
                                "if": "{{!_local.forgotPasswordSuccess}}",
                                "props": {
                                    "type": "submit",
                                    "className": "cs-primary-button",
                                    "disabled": "{{_local.isSendingReset}}"
                                },
                                "children": [
                                    {
                                        "type": "basic",
                                        "name": "Span",
                                        "text": "{{_local.isSendingReset ? \"Sending Reset Link...\" : \"Send Reset Link\"}}"
                                    }
                                ]
                            },
                            {
                                "type": "basic",
                                "name": "Div",
                                "props": {
                                    "className": "cs-auth-inline-links"
                                },
                                "children": [
                                    {
                                        "type": "basic",
                                        "name": "Button",
                                        "props": {
                                            "type": "button",
                                            "className": "cs-auth-link"
                                        },
                                        "actions": [
                                            {
                                                "type": "click",
                                                "handler": "navigate",
                                                "params": {
                                                    "path": "/login"
                                                }
                                            }
                                        ],
                                        "children": [
                                            {
                                                "type": "basic",
                                                "name": "Span",
                                                "text": "Back to Login"
                                            }
                                        ]
                                    },
                                    {
                                        "type": "basic",
                                        "name": "Button",
                                        "props": {
                                            "type": "button",
                                            "className": "cs-auth-link"
                                        },
                                        "actions": [
                                            {
                                                "type": "click",
                                                "handler": "navigate",
                                                "params": {
                                                    "path": "/register"
                                                }
                                            }
                                        ],
                                        "children": [
                                            {
                                                "type": "basic",
                                                "name": "Span",
                                                "text": "Create Account"
                                            }
                                        ]
                                    }
                                ]
                            }
                        ]
                    }
                ]
            }
        ],
        "side_content": [
            {
                "id": "auth_forgot_password_summary",
                "type": "basic",
                "name": "Div",
                "props": {
                    "className": "cs-panel cs-summary-panel"
                },
                "children": [
                    {
                        "type": "basic",
                        "name": "H2",
                        "props": {
                            "className": "cs-block-title"
                        },
                        "text": "Recovery Flow"
                    },
                    {
                        "type": "basic",
                        "name": "P",
                        "props": {
                            "className": "cs-summary-line"
                        },
                        "text": "1. The template sends the email field to the existing /api/auth/forgot-password endpoint through apiCall."
                    },
                    {
                        "type": "basic",
                        "name": "P",
                        "props": {
                            "className": "cs-summary-line"
                        },
                        "text": "2. Validation problems return to the same page and render under the email field."
                    },
                    {
                        "type": "basic",
                        "name": "P",
                        "props": {
                            "className": "cs-summary-line"
                        },
                        "text": "3. On success, the page shows a confirmation state without breaking the consultation template shell."
                    }
                ]
            }
        ],
        "footer_notice": [
            {
                "id": "auth_forgot_password_notice",
                "type": "basic",
                "name": "Div",
                "props": {
                    "className": "cs-panel"
                },
                "children": [
                    {
                        "type": "basic",
                        "name": "P",
                        "props": {
                            "className": "cs-page-copy"
                        },
                        "text": "Password recovery keeps the same consultation-studio inheritance and uses the existing auth API without adding a separate page system."
                    }
                ]
            }
        ]
    }
}
