{
  "version": "1.0.0",
  "layout_name": "consultation_home",
  "permissions": [],
  "data_sources": [
    {
      "id": "reservation",
      "type": "api",
      "endpoint": "/api/modules/consultation-reservation/context",
      "method": "GET",
      "auto_fetch": true,
      "loading_strategy": "progressive",
      "fallback": {
        "consultation_types": [
          {
            "id": 1,
            "name": "Initial Consultation",
            "description": "A first-time intake session."
          },
          {
            "id": 2,
            "name": "Follow-up Session",
            "description": "A progress review with an advisor."
          }
        ],
        "branches": [
          {
            "id": 1,
            "name": "Central Studio"
          },
          {
            "id": 2,
            "name": "Riverfront Studio"
          }
        ],
        "available_dates": [],
        "available_slots": [],
        "summary": {
          "headline": "Reserve a consultation in a guided four-step flow."
        },
        "lookup": {}
      }
    }
  ],
  "slots": {
    "content": [
      {
        "id": "progress_header",
        "type": "basic",
        "name": "Div",
        "props": {
          "className": "cs-panel"
        },
        "children": [
          {
            "type": "basic",
            "name": "Span",
            "props": {
              "className": "cs-step-label"
            },
            "text": "Step 1 of 4"
          },
          {
            "type": "basic",
            "name": "H1",
            "props": {
              "className": "cs-page-title"
            },
            "text": "Consultation Reservation"
          },
          {
            "type": "basic",
            "name": "P",
            "props": {
              "className": "cs-page-copy"
            },
            "text": "{{reservation.summary && reservation.summary.headline ? reservation.summary.headline : 'Reserve a consultation in a guided four-step flow.'}}"
          }
        ]
      },
      {
        "id": "consultation_type_selector",
        "type": "basic",
        "name": "Div",
        "props": {
          "className": "cs-panel"
        },
        "children": [
          {
            "type": "basic",
            "name": "H2",
            "props": {
              "className": "cs-block-title"
            },
            "text": "Consultation Types"
          },
          {
            "type": "basic",
            "name": "Div",
            "iteration": {
              "source": "{{reservation.consultation_types ?? []}}",
              "item_var": "item"
            },
            "props": {
              "className": "cs-card-list"
            },
            "children": [
              {
                "type": "basic",
                "name": "Div",
                "props": {
                  "className": "cs-option-card"
                },
                "children": [
                  {
                    "type": "basic",
                    "name": "H3",
                    "props": {
                      "className": "cs-option-title"
                    },
                    "text": "{{item.name ?? ''}}"
                  },
                  {
                    "type": "basic",
                    "name": "P",
                    "props": {
                      "className": "cs-option-copy"
                    },
                    "text": "{{item.description ?? ''}}"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "id": "branch_selector",
        "type": "basic",
        "name": "Div",
        "props": {
          "className": "cs-panel"
        },
        "children": [
          {
            "type": "basic",
            "name": "H2",
            "props": {
              "className": "cs-block-title"
            },
            "text": "Branches"
          },
          {
            "type": "basic",
            "name": "P",
            "props": {
              "className": "cs-block-note"
            },
            "text": "{{_global.consultationStudioBrand && _global.consultationStudioBrand.branchNotice ? _global.consultationStudioBrand.branchNotice : ''}}"
          },
          {
            "type": "basic",
            "name": "Div",
            "iteration": {
              "source": "{{reservation.branches ?? []}}",
              "item_var": "item"
            },
            "props": {
              "className": "cs-chip-list"
            },
            "children": [
              {
                "type": "basic",
                "name": "Span",
                "props": {
                  "className": "cs-chip"
                },
                "text": "{{item.name ?? ''}}"
              }
            ]
          }
        ]
      },
      {
        "id": "reservation_summary",
        "type": "basic",
        "name": "Div",
        "props": {
          "className": "cs-panel cs-summary-panel"
        },
        "children": [
          {
            "type": "basic",
            "name": "H2",
            "props": {
              "className": "cs-block-title"
            },
            "text": "What to Expect"
          },
          {
            "type": "basic",
            "name": "P",
            "props": {
              "className": "cs-page-copy"
            },
            "text": "Choose a consultation type, select a branch and slot, verify your email, and review the final summary."
          },
          {
            "type": "basic",
            "name": "Button",
            "props": {
              "type": "button",
              "className": "cs-primary-button"
            },
            "actions": [
              {
                "type": "click",
                "handler": "navigate",
                "params": {
                  "path": "/consultation/reserve"
                }
              }
            ],
            "children": [
              {
                "type": "basic",
                "name": "Span",
                "text": "Start Reservation"
              }
            ]
          }
        ]
      }
    ]
  }
}
