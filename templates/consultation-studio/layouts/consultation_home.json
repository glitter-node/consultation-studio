{
  "version": "1.0.0",
  "layout_name": "consultation_home",
  "extends": "_consultation_public_base",
  "permissions": [],
  "meta": {
    "title": "Consultation Portal"
  },
  "slots": {
    "hero": [
      {
        "id": "home_hero",
        "type": "basic",
        "name": "Div",
        "props": {
          "className": "cs-panel cs-home-hero"
        },
        "children": [
          {
            "type": "basic",
            "name": "Span",
            "props": {
              "className": "cs-step-label"
            },
            "text": "Consultation Portal"
          },
          {
            "type": "basic",
            "name": "H1",
            "props": {
              "className": "cs-page-title"
            },
            "text": "Educational Consultation Reservation"
          }
        ]
      }
    ],
    "page_intro": [
      {
        "id": "home_intro",
        "type": "basic",
        "name": "Div",
        "props": {
          "className": "cs-panel"
        },
        "children": [
          {
            "type": "basic",
            "name": "P",
            "props": {
              "className": "cs-page-copy"
            },
            "text": "Plan a guided reservation flow for admissions consultation, verify your contact information, and review your reservation status from one formal portal."
          }
        ]
      }
    ],
    "main_content": [
      {
        "id": "home_overview_cards",
        "type": "basic",
        "name": "Div",
        "props": {
          "className": "cs-card-list"
        },
        "children": [
          {
            "type": "basic",
            "name": "Div",
            "props": {
              "className": "cs-panel"
            },
            "children": [
              {
                "type": "basic",
                "name": "H2",
                "props": {
                  "className": "cs-block-title"
                },
                "text": "Reserve"
              },
              {
                "type": "basic",
                "name": "P",
                "props": {
                  "className": "cs-page-copy"
                },
                "text": "Choose a consultation service, select a date, and confirm your time slot."
              },
              {
                "type": "basic",
                "name": "Button",
                "props": {
                  "type": "button",
                  "className": "cs-primary-button"
                },
                "actions": [
                  {
                    "type": "click",
                    "handler": "navigate",
                    "params": {
                      "path": "/consultation/reserve"
                    }
                  }
                ],
                "children": [
                  {
                    "type": "basic",
                    "name": "Span",
                    "text": "Start Reservation"
                  }
                ]
              }
            ]
          },
          {
            "type": "basic",
            "name": "Div",
            "props": {
              "className": "cs-panel"
            },
            "children": [
              {
                "type": "basic",
                "name": "H2",
                "props": {
                  "className": "cs-block-title"
                },
                "text": "Lookup"
              },
              {
                "type": "basic",
                "name": "P",
                "props": {
                  "className": "cs-page-copy"
                },
                "text": "Review the current state of an existing reservation by using your registered contact number."
              },
              {
                "type": "basic",
                "name": "Button",
                "props": {
                  "type": "button",
                  "className": "cs-secondary-button"
                },
                "actions": [
                  {
                    "type": "click",
                    "handler": "navigate",
                    "params": {
                      "path": "/consultation/lookup"
                    }
                  }
                ],
                "children": [
                  {
                    "type": "basic",
                    "name": "Span",
                    "text": "Lookup Reservation"
                  }
                ]
              }
            ]
          }
        ]
      }
    ],
    "side_content": [
      {
        "id": "home_process_summary",
        "type": "basic",
        "name": "Div",
        "props": {
          "className": "cs-panel cs-summary-panel"
        },
        "children": [
          {
            "type": "basic",
            "name": "H2",
            "props": {
              "className": "cs-block-title"
            },
            "text": "Portal Flow"
          },
          {
            "type": "basic",
            "name": "P",
            "props": {
              "className": "cs-summary-line"
            },
            "text": "1. Select a consultation service"
          },
          {
            "type": "basic",
            "name": "P",
            "props": {
              "className": "cs-summary-line"
            },
            "text": "2. Confirm date and time"
          },
          {
            "type": "basic",
            "name": "P",
            "props": {
              "className": "cs-summary-line"
            },
            "text": "3. Verify your email"
          },
          {
            "type": "basic",
            "name": "P",
            "props": {
              "className": "cs-summary-line"
            },
            "text": "4. Review or lookup your reservation"
          }
        ]
      }
    ],
    "footer_notice": [
      {
        "id": "home_notice",
        "type": "basic",
        "name": "Div",
        "props": {
          "className": "cs-panel"
        },
        "children": [
          {
            "type": "basic",
            "name": "P",
            "props": {
              "className": "cs-page-copy"
            },
            "text": "{{_global.consultationStudioBrand && _global.consultationStudioBrand.branchNotice ? _global.consultationStudioBrand.branchNotice : ''}}"
          }
        ]
      }
    ]
  }
}
