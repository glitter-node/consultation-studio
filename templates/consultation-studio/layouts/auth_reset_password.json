{
    "version": "1.0.0",
    "layout_name": "auth_reset_password",
    "extends": "_consultation_public_base",
    "permissions": [],
    "meta": {
        "title": "Consultation Reset Password"
    },
    "data_sources": [
        {
            "id": "reset_token_validation",
            "type": "api",
            "endpoint": "/api/auth/validate-reset-token",
            "method": "POST",
            "auto_fetch": true,
            "auth_required": false,
            "params": {
                "token": "{{query.token ?? \"\"}}",
                "email": "{{query.email ?? \"\"}}"
            },
            "loading_strategy": "blocking",
            "initLocal": {
                "tokenValid": "{{data.valid ?? false}}"
            },
            "errorHandling": {
                "422": {
                    "handler": "setState",
                    "params": {
                        "target": "local",
                        "tokenValid": false,
                        "tokenError": "This password reset link is invalid or has expired."
                    }
                },
                "default": {
                    "handler": "setState",
                    "params": {
                        "target": "local",
                        "tokenValid": false,
                        "tokenError": "Unable to verify the password reset link right now."
                    }
                }
            }
        }
    ],
    "init_actions": [
        {
            "handler": "setState",
            "params": {
                "target": "local",
                "isResettingPassword": false,
                "resetPasswordError": null,
                "resetPasswordErrors": null,
                "resetPasswordSuccess": false,
                "tokenError": null,
                "tokenValid": false
            }
        }
    ],
    "slots": {
        "hero": [
            {
                "id": "auth_reset_password_hero",
                "type": "basic",
                "name": "Div",
                "props": {
                    "className": "cs-panel cs-home-hero"
                },
                "children": [
                    {
                        "type": "basic",
                        "name": "Span",
                        "props": {
                            "className": "cs-step-label"
                        },
                        "text": "Reset Password"
                    },
                    {
                        "type": "basic",
                        "name": "H1",
                        "props": {
                            "className": "cs-page-title"
                        },
                        "text": "Choose a New Password"
                    }
                ]
            }
        ],
        "page_intro": [
            {
                "id": "auth_reset_password_intro",
                "type": "basic",
                "name": "Div",
                "props": {
                    "className": "cs-panel"
                },
                "children": [
                    {
                        "type": "basic",
                        "name": "P",
                        "props": {
                            "className": "cs-page-copy"
                        },
                        "text": "Use the reset link from your email to verify the token and create a new password inside the consultation template."
                    }
                ]
            }
        ],
        "main_content": [
            {
                "id": "auth_reset_password_content",
                "type": "basic",
                "name": "Div",
                "props": {
                    "className": "cs-page-grid cs-lookup-shell"
                },
                "children": [
                    {
                        "id": "auth_reset_password_form",
                        "type": "basic",
                        "name": "Form",
                        "props": {
                            "id": "auth_reset_password_form",
                            "className": "cs-panel cs-form-grid"
                        },
                        "actions": [
                            {
                                "type": "submit",
                                "handler": "sequence",
                                "actions": [
                                    {
                                        "handler": "setState",
                                        "params": {
                                            "target": "local",
                                            "isResettingPassword": true,
                                            "resetPasswordError": null,
                                            "resetPasswordErrors": null
                                        }
                                    },
                                    {
                                        "handler": "apiCall",
                                        "target": "/api/auth/reset-password",
                                        "params": {
                                            "method": "POST",
                                            "body": {
                                                "email": "{{query.email ?? \"\"}}",
                                                "token": "{{query.token ?? \"\"}}",
                                                "password": "{{form.password}}",
                                                "password_confirmation": "{{form.password_confirmation}}"
                                            }
                                        },
                                        "onSuccess": [
                                            {
                                                "handler": "setState",
                                                "params": {
                                                    "target": "local",
                                                    "isResettingPassword": false,
                                                    "resetPasswordError": null,
                                                    "resetPasswordErrors": null,
                                                    "resetPasswordSuccess": true
                                                }
                                            },
                                            {
                                                "handler": "navigate",
                                                "params": {
                                                    "path": "/login"
                                                }
                                            }
                                        ],
                                        "onError": [
                                            {
                                                "handler": "setState",
                                                "params": {
                                                    "target": "local",
                                                    "isResettingPassword": false,
                                                    "resetPasswordError": "{{error.response?.message ?? error.message}}",
                                                    "resetPasswordErrors": "{{error.response?.errors ?? error.errors}}"
                                                }
                                            }
                                        ]
                                    }
                                ]
                            }
                        ],
                        "children": [
                            {
                                "type": "basic",
                                "name": "H2",
                                "props": {
                                    "className": "cs-block-title"
                                },
                                "text": "Create New Password"
                            },
                            {
                                "type": "basic",
                                "name": "P",
                                "if": "{{_local.tokenError}}",
                                "props": {
                                    "className": "cs-auth-message cs-auth-message-error",
                                    "role": "alert",
                                    "aria-live": "polite"
                                },
                                "text": "{{_local.tokenError}}"
                            },
                            {
                                "type": "basic",
                                "name": "P",
                                "if": "{{_local.resetPasswordError}}",
                                "props": {
                                    "className": "cs-auth-message cs-auth-message-error",
                                    "role": "alert",
                                    "aria-live": "polite"
                                },
                                "text": "{{_local.resetPasswordError}}"
                            },
                            {
                                "type": "basic",
                                "name": "Div",
                                "if": "{{_local.resetPasswordSuccess}}",
                                "props": {
                                    "className": "cs-auth-message cs-auth-message-success",
                                    "role": "status",
                                    "aria-live": "polite"
                                },
                                "children": [
                                    {
                                        "type": "basic",
                                        "name": "P",
                                        "text": "Your password has been updated successfully. Redirecting to login..."
                                    }
                                ]
                            },
                            {
                                "type": "basic",
                                "name": "Div",
                                "if": "{{!query.token || !query.email}}",
                                "props": {
                                    "className": "cs-auth-message cs-auth-message-error",
                                    "role": "alert",
                                    "aria-live": "polite"
                                },
                                "children": [
                                    {
                                        "type": "basic",
                                        "name": "P",
                                        "text": "This password reset link is incomplete. Request a new reset email and try again."
                                    }
                                ]
                            },
                            {
                                "type": "basic",
                                "name": "Div",
                                "if": "{{query.token && query.email && _local.tokenValid && !_local.resetPasswordSuccess}}",
                                "children": [
                                    {
                                        "type": "basic",
                                        "name": "Div",
                                        "children": [
                                            {
                                                "type": "basic",
                                                "name": "Label",
                                                "props": {
                                                    "className": "cs-summary-label"
                                                },
                                                "text": "New Password"
                                            },
                                            {
                                                "type": "basic",
                                                "name": "Input",
                                                "props": {
                                                    "name": "password",
                                                    "type": "password",
                                                    "placeholder": "Enter a new password",
                                                    "className": "cs-input",
                                                    "disabled": "{{_local.isResettingPassword}}",
                                                    "required": true
                                                }
                                            },
                                            {
                                                "type": "basic",
                                                "name": "P",
                                                "if": "{{_local.resetPasswordErrors?.password}}",
                                                "props": {
                                                    "className": "cs-auth-field-error"
                                                },
                                                "text": "{{Array.isArray(_local.resetPasswordErrors?.password) ? _local.resetPasswordErrors.password[0] : _local.resetPasswordErrors?.password}}"
                                            }
                                        ]
                                    },
                                    {
                                        "type": "basic",
                                        "name": "Div",
                                        "children": [
                                            {
                                                "type": "basic",
                                                "name": "Label",
                                                "props": {
                                                    "className": "cs-summary-label"
                                                },
                                                "text": "Confirm Password"
                                            },
                                            {
                                                "type": "basic",
                                                "name": "Input",
                                                "props": {
                                                    "name": "password_confirmation",
                                                    "type": "password",
                                                    "placeholder": "Confirm your new password",
                                                    "className": "cs-input",
                                                    "disabled": "{{_local.isResettingPassword}}",
                                                    "required": true
                                                }
                                            },
                                            {
                                                "type": "basic",
                                                "name": "P",
                                                "if": "{{_local.resetPasswordErrors?.password_confirmation}}",
                                                "props": {
                                                    "className": "cs-auth-field-error"
                                                },
                                                "text": "{{Array.isArray(_local.resetPasswordErrors?.password_confirmation) ? _local.resetPasswordErrors.password_confirmation[0] : _local.resetPasswordErrors?.password_confirmation}}"
                                            }
                                        ]
                                    },
                                    {
                                        "type": "basic",
                                        "name": "Button",
                                        "props": {
                                            "type": "submit",
                                            "className": "cs-primary-button",
                                            "disabled": "{{_local.isResettingPassword}}"
                                        },
                                        "children": [
                                            {
                                                "type": "basic",
                                                "name": "Span",
                                                "text": "{{_local.isResettingPassword ? \"Updating Password...\" : \"Reset Password\"}}"
                                            }
                                        ]
                                    }
                                ]
                            },
                            {
                                "type": "basic",
                                "name": "Div",
                                "props": {
                                    "className": "cs-auth-inline-links"
                                },
                                "children": [
                                    {
                                        "type": "basic",
                                        "name": "Button",
                                        "props": {
                                            "type": "button",
                                            "className": "cs-auth-link"
                                        },
                                        "actions": [
                                            {
                                                "type": "click",
                                                "handler": "navigate",
                                                "params": {
                                                    "path": "/login"
                                                }
                                            }
                                        ],
                                        "children": [
                                            {
                                                "type": "basic",
                                                "name": "Span",
                                                "text": "Back to Login"
                                            }
                                        ]
                                    },
                                    {
                                        "type": "basic",
                                        "name": "Button",
                                        "props": {
                                            "type": "button",
                                            "className": "cs-auth-link"
                                        },
                                        "actions": [
                                            {
                                                "type": "click",
                                                "handler": "navigate",
                                                "params": {
                                                    "path": "/forgot-password"
                                                }
                                            }
                                        ],
                                        "children": [
                                            {
                                                "type": "basic",
                                                "name": "Span",
                                                "text": "Request New Reset Link"
                                            }
                                        ]
                                    }
                                ]
                            }
                        ]
                    }
                ]
            }
        ],
        "side_content": [
            {
                "id": "auth_reset_password_summary",
                "type": "basic",
                "name": "Div",
                "props": {
                    "className": "cs-panel cs-summary-panel"
                },
                "children": [
                    {
                        "type": "basic",
                        "name": "H2",
                        "props": {
                            "className": "cs-block-title"
                        },
                        "text": "Reset Flow"
                    },
                    {
                        "type": "basic",
                        "name": "P",
                        "props": {
                            "className": "cs-summary-line"
                        },
                        "text": "1. The page verifies the token and email through /api/auth/validate-reset-token as soon as the reset link opens."
                    },
                    {
                        "type": "basic",
                        "name": "P",
                        "props": {
                            "className": "cs-summary-line"
                        },
                        "text": "2. Only valid links reveal the reset form, while invalid or expired links show an error state."
                    },
                    {
                        "type": "basic",
                        "name": "P",
                        "props": {
                            "className": "cs-summary-line"
                        },
                        "text": "3. Submitting the new password calls /api/auth/reset-password and returns the user to the login page."
                    }
                ]
            }
        ],
        "footer_notice": [
            {
                "id": "auth_reset_password_notice",
                "type": "basic",
                "name": "Div",
                "props": {
                    "className": "cs-panel"
                },
                "children": [
                    {
                        "type": "basic",
                        "name": "P",
                        "props": {
                            "className": "cs-page-copy"
                        },
                        "text": "This reset page uses the existing Gnuboard 7 reset-token validation and password update APIs inside the consultation-studio template shell."
                    }
                ]
            }
        ]
    }
}
